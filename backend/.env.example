# ── Application ────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB ─────────────────────────────────────────────────────
# Remplacez par votre URI MongoDB Atlas ou locale
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/streamvibe?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────────────
# Générez un secret long et aléatoire (ex: openssl rand -hex 64)
JWT_SECRET=CHANGE_ME_TO_A_VERY_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d

# ── Admin par défaut ─────────────────────────────────────────────
# Ces valeurs créent l'admin lors du 1er démarrage
ADMIN_EMAIL=admin@streamvibe.com
ADMIN_PASSWORD=Admin123!

# ── CORS ─────────────────────────────────────────────────────────
# URL de votre frontend en production (ex: https://streamvibe.com)
FRONTEND_URL=http://localhost:5500
